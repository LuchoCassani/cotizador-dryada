PORT=3001

# Panel de administración
# Contraseña para acceder al panel /admin. Sin esta variable, el panel queda deshabilitado.
ADMIN_PASSWORD=cambia-esto-antes-de-usar

# Gmail SMTP con App Password
# Pasos: Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cotizador@dryada.com
SMTP_PASS=abcd efgh ijkl mnop
EMAIL_FROM="Cotizador Dryada <cotizador@dryada.com>"

UPLOAD_MAX_MB=50

# Base de datos SQLite
DB_PATH=./data/cotizador.db

# PrusaSlicer — si no está disponible, el sistema usa cálculo geométrico como fallback
# En producción (Docker), el bin ya está en /usr/local/bin/prusa-slicer por la imagen base.
# En desarrollo local fuera de Docker: apuntar al binario instalado en el host.
# macOS con AppImage: /Applications/PrusaSlicer.app/Contents/MacOS/PrusaSlicer
# Linux: /usr/bin/prusa-slicer o ruta al AppImage extraído
PRUSASLICER_BIN=prusa-slicer
PRUSA_LAYER_HEIGHT=0.20
UPLOADS_DIR=/tmp/cotizador-uploads
# Timeout en milisegundos para el proceso de slicing (default: 5 minutos)
# En servidores con CPU limitada (Oracle Cloud free tier) puede necesitar más tiempo.
PRUSA_TIMEOUT_MS=300000
