SMTP_PORT=587
SMTP_USER=cotizador@dryada.com
SMTP_PASS=abcd efgh ijkl mnop
EMAIL_FROM="Cotizador Dryada <cotizador@dryada.com>"

UPLOAD_MAX_MB=50

# Base de datos SQLite
DB_PATH=./data/cotizador.db
